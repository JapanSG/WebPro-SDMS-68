<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>login</title>
    <link rel="stylesheet" href="/css/login.css">
</head>

<body>
    <div class="container">

        <div class="background">

        </div>
        <div class="login-container">

            <div class="login">
                <div class="login-header">
                    <h1>login</h1>
                    <p>Verify your identity with Google or your school account.</p>
                </div>
                <div class="login-body">
                    <form action="/student/home" method="get" class="login-form">
                        <h2>Username</h2>
                        <input type="text" name="username" placeholder="Username" class="input-field">
                        <div class="input-label">
                            <h2>Password</h2>
                            <p class="forgot-password">forgot your password?</p>
                        </div>
                        <div class="password-wrapper">
                            <input type="password" name="password" placeholder="Password" class="input-field">
                            <span class="toggle-icon"><img src="/images/icons/PasswordToggle.png" alt="Password Toggle"></span>
                        </div>
                        
                        <button type="submit" class="login-btn">
                            <img src="/images/icons/Login.svg" alt="login">
                            Login
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>





</body>

</html>