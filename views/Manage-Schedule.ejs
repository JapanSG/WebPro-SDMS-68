<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Schedule</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/manage-schedule.css">
    
</head>
<body>

    <%- include('Menu-AS') %>
    <%- include('showMenu') %>

    <div class="container">

        <div class="toolbar">
            <input type="text" id="searchInput" class="search-box" placeholder="🔍 ค้นหาห้องเรียน หรือ ชื่อครู">

            <form action="/admin/manage-schedule" method="GET" class="filters" id="filterForm">
                <label>ปีการศึกษา</label>
                <select name="year" onchange="document.getElementById('filterForm').submit();">
                    <% years.forEach(y => { %>
                        <option value = "<%= y %>" <%= y === selectedYear ? 'selected' : '' %>><%= y %></option>
                    <% }) %>
                </select> 

                <label>เทอม</label>
                <select name="semester" onchange="document.getElementById('filterForm').submit();">
                    <% semesters.forEach(s => { %>
                        <option value = "<%= s %>" <%= s === selectedSemester ? 'selected' : '' %>><%= s %></option>
                    <% }) %>
                </select>
            </form>
        </div>

        <div id="roomsContainer">
            <%
                let currentGrade = '';
                const MAX_PERIODS = 35;

                rooms.forEach(room =>{
                    if (room.grade_level !== currentGrade){
                        if (currentGrade !== ''){
            %>
                            </div></div> <%
                        }
                        currentGrade = room.grade_level;
            %>
                        <div class ="grade-section" data-grade="ประถมศึกษาปีที่ <%= currentGrade %>">
                            <div class = "grade-title">ระดับชั้นประถมศึกษาปีที่ <%= currentGrade %></div>
                            <div class = "card-grid">
            <%
                    }

                    let scheduleCount = room.schedule_count || 0;
                    let percentage = (scheduleCount/ MAX_PERIODS) * 100;
                    let statusText = 'ว่าง';
                    let barColorClass = 'status-empty';

                    if(scheduleCount >= MAX_PERIODS){
                        statusText = 'สมบูรณ์';
                        barColorClass = 'status-complete';
                        percentage = 100;
                    } else if(scheduleCount > 0){
                        statusText = 'กำลังดำเนินการ';
                        barColorClass = 'status-incomplete';
                    }
            %>
                            <div class ="card room-card">
                                <h3 class="room-name">ห้อง <%= room.room_name %></h3>
                                <p class="teacher-name">
                                    คุณครู: <%= room.first_name ? room.first_name + ' ' + room.last_name : 'ยังไม่มีในระบบ' %>
                                </p>
                                <p>สถานะ: <strong><%= statusText %></strong></p>

                                <div class="progress-container">
                                    <div class="progress-bar <%= barColorClass %>" style="width: <%= percentage %>%;"></div>
                                </div>

                                <strong><%= scheduleCount %>/<%= MAX_PERIODS %> คาบ</strong>
                                <br>

                                <% if (room.room_id !== 0) { %>
                                    <a href="/admin/manage-schedule/inside/<%=room.room_id %>?year=<%= selectedYear %>&semester=<%= selectedSemester %>" class = "btn-edit">✎ แก้ไขตาราง</a>
                                <% } else { %>
                                    <a href="/admin/manage-schedule/inside/new?grade=<%= room.grade_level %>&room=<%= encodeURIComponent(room.room_name)%>&year=<%= selectedYear %>&semester=<%= selectedSemester %>" class="btn-edit">✎ สร้างและจัดตาราง</a>
                                <% } %>
                            </div>
            <%
                });
                if (rooms.length > 0){
            %>
                </div></div> <% } %>
        </div>
    </div>

    <script>
        // search

        //รับเหตุการณ์ด้วย addeventlistener id = input พวกคำพิ้มคือ e
        document.getElementById('searchInput').addEventListener('input',function(e){
            const seacrhTerm = e.target.value.toLowerCase().trim(); // text in input
            const gradeSections = document.querySelectorAll('.grade-section'); //เอาส่วนgrade levelมาหมด

            gradeSections.forEach(section=>{
                let hasVisibleCard = false; //เป็นตัวกำหนด grade level จะให้โชว์
                const cards = section.querySelectorAll('.room-card'); // เอาส่วนห้องแต่ละ grade level มาหมด

                cards.forEach(card=>{
                    const roomName = card.querySelector('.room-name').textContent.toLocaleLowerCase();
                    const teacherName = card.querySelector('.teacher-name').textContent.toLocaleLowerCase();

                    //ข้อความที่เรา serach ตรงกับห้องไหน กับ ชื่อครูคนไหนมั้ย
                    if (roomName.includes(seacrhTerm) || teacherName.includes(seacrhTerm)){
                        card.style.display = 'block';
                        hasVisibleCard = true;
                    }
                    else{
                        card.style.display = 'none';
                    }
                });

                if (hasVisibleCard){
                    section.style.display = 'block';
                }
                else{
                    section.style.display = 'none';
                }
            });
        });
    </script>
</body>
</html>

