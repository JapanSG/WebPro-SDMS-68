<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Schedule</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/manage-schedule.css">
    <link rel="icon" type="image/svg+xml" href="/images/icons/school.svg">
</head>
<body>

    <%- include('Menu-AS') %>
    <%- include('showMenu') %>

    <div class="container">

        <div class="toolbar">
            <input type="text" id="searchInput" class="search-box" placeholder="🔍 ค้นหาห้องเรียน หรือ ชื่อครูประจำชั้น...">

            <form action="/admin/manage-schedule" method="GET" class="filters" id="filterForm">
                <label>ปีการศึกษา</label>
                <select name="year" onchange="document.getElementById('filterForm').submit();">
                    <% years.forEach(y => { %>
                        <option value="<%= y %>" <%= y === selectedYear ? 'selected' : '' %>>ปี <%= y %></option>
                    <% }) %>
                </select> 

                <label>ภาคเรียน</label>
                <select name="semester" onchange="document.getElementById('filterForm').submit();">
                    <% semesters.forEach(s => { %>
                        <option value="<%= s %>" <%= s === selectedSemester ? 'selected' : '' %>>เทอม <%= s %></option>
                    <% }) %>
                </select>
            </form>
        </div>

        <div id="roomsContainer">
            <%
                let currentGrade = '';
                const MAX_PERIODS = 35;

                rooms.forEach(room => {
                    if (room.grade_level !== currentGrade){
                        if (currentGrade !== ''){
            %>
                            </div></div> <%
                        }
                        currentGrade = room.grade_level;
            %>
                        <div class="grade-section" data-grade="ประถมศึกษาปีที่ <%= currentGrade %>">
                            <div class="grade-title">ระดับชั้นประถมศึกษาปีที่ <%= currentGrade %></div>
                            <div class="card-grid">
            <%
                    }

                    let scheduleCount = room.schedule_count || 0;
                    let percentage = (scheduleCount / MAX_PERIODS) * 100;
                    let statusText = 'ว่าง';
                    let barColorClass = 'status-empty';

                    if(scheduleCount >= MAX_PERIODS){
                        statusText = 'สมบูรณ์';
                        barColorClass = 'status-complete';
                        percentage = 100;
                    } else if(scheduleCount > 0){
                        statusText = 'กำลังดำเนินการ';
                        barColorClass = 'status-incomplete';
                    }
            %>
                                <div class="card room-card">
                                    <h3 class="room-name">ห้อง <%= room.room_name %></h3>
                                    <p class="teacher-name">
                                        ครูประจำชั้น: <br>
                                        <strong style="color: #334155;"><%= room.first_name ? room.first_name + ' ' + room.last_name : 'ยังไม่มีในระบบ' %></strong>
                                    </p>
                                    
                                    <p style="font-size: 0.9rem; margin: 0;">สถานะ: <span style="color: var(--primary-color); font-weight: bold;"><%= statusText %></span></p>

                                    <div class="progress-container">
                                        <div class="progress-bar <%= barColorClass %>" style="width: <%= percentage %>%;"></div>
                                    </div>

                                    <span class="progress-text"><%= scheduleCount %> / <%= MAX_PERIODS %> คาบ</span>
                                    <br>

                                    <% if (room.room_id !== 0) { %> <a href="/admin/manage-schedule/inside/<%= room.room_id %>?year=<%= selectedYear %>&semester=<%= selectedSemester %>" class="btn-edit">✎ จัดการตารางเรียน</a>
                                    <% } else { %>
                                        <a href="/admin/manage-schedule/inside/new?grade=<%= room.grade_level %>&room=<%= encodeURIComponent(room.room_name) %>&year=<%= selectedYear %>&semester=<%= selectedSemester %>" class="btn-edit">✎ สร้างตารางใหม่</a>
                                    <% } %>
                                </div>
            <%
                });
                if (rooms.length > 0){
            %>
                </div></div> <% } %>
        </div>
    </div>

    <script>
        // ระบบค้นหาห้องและชื่อครู (Client-side Search)
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase().trim();
            const gradeSections = document.querySelectorAll('.grade-section');

            gradeSections.forEach(section => {
                let hasVisibleCard = false;
                const cards = section.querySelectorAll('.room-card');

                cards.forEach(card => {
                    const roomName = card.querySelector('.room-name').textContent.toLowerCase();
                    const teacherName = card.querySelector('.teacher-name').textContent.toLowerCase();

                    if (roomName.includes(searchTerm) || teacherName.includes(searchTerm)){
                        card.style.display = 'flex'; // สำคัญ: ใช้ flex แทน block เพื่อให้โครงสร้างการ์ดไม่พัง
                        hasVisibleCard = true;
                    } else {
                        card.style.display = 'none';
                    }
                });

                if (hasVisibleCard) {
                    section.style.display = 'block';
                } else {
                    section.style.display = 'none';
                }
            });
        });
    </script>
</body>
</html>