<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Schedule</title>
    <link rel="stylesheets" href="/css/global.css">
</head>
<body>

    <%- include('header') %>
    <%- include('showMenu') %>

    <div class="container">

        <div class="toolbar">
            <input type="text" id="searchInput" class="search-box" placeholder="🔍 ค้นหาห้องเรียน หรือ ชื่อครู">

            <form action="/manage-schedule" method="GET" class="filters" id="filterForm">
                <label>ปีการศึกษา</label>
                <select name="year" onchange="document.getElementById('filterForm').submit();">
                    <% years.forEach(y => { %>
                        <option value = "<%= y %>" <%= y === slectedYear ? 'seleted' : '' %>><%= y %></option>
                    <% }) %>
                </select> 

                <label>เทอม</label>
                <select name="semester" onchange="document.getElementById('filterForm').submit()">
                    <% semesters.forEach(s => { %>
                        <option value = "<%= s %>" <%= s === selectedSemester ? 'seleted' : '' %>><%= s %></option>
                    <% }) %>
                </select>
            </form>
        </div>

        <div id="roomsContainer">
            <%
                let currentGrade = '';
                const MAX_PERIODS = 35;
                
                rooms.forEach(room =>{
                    <!-- ถ้าเปลี่ยนระดับ ให้สร้างsectionใหม่ -->
                    if (room.grade_level !== currentGrade){
                        if (currenyGrade !== ''){
            %>
                            </div></div> <%
                        }
                        currentGrade = room.grade_level;
            %>
                        <div class ="grade-scetion" data-grade="ประถมศึกษาปีที่ <%= currentGrade %>">
                            <div class = "grade-title">ระดับชั้นประถมศึกษาปีที่ <%= currentGrade %></div>
                            <div class = "card-grid">
            <%
                    }
                    
                    <!-- คำนวณหลอด Progress Bar และ สถานะ -->
                    let scheduleCount = room.schedule_count || 0;
                    let percentage = (scheduleCount/ MAX_PERIODS) * 100;
                    let statusText = 'ว่าง';
                    let barColorClass = 'status-empty';

                    if(scheduleCount >= MAX_PERIODS){
                        statusText = 'สมบูรณ์';
                        barColorClass = 'status-complete';
                        percentage = 100;
                    } else if(scheduleCount > 0){
                        statusText = 'กำลังดำเนินการ';
                        barColorClass = 'status-incomplete';
                    }
            %>
                            <div class ="card room-card">
                                <h3 class="room-name">ห้อง <$= room.room_name $></h3>
                                <p class="teacher-name">
                                    คุณครู: <%= room.first_name ? room.first_name + ' ' + room.last_name : 'ยังไม่มีในระบบ' %>
                                </p>
                                <p>สถานะ: <strong><%= statusText %></strong></p>

                                <div class="progress-container">
                                    <div class="progress-bar <%= barColorClass %>" style="width: <%= percentage %>;"></div>
                                </div>

                                <strong><%= scheduleCount %>/<%= MAX_PERIODS %> คาบ</strong>
                                <br>

                                <% if (room.room_id !== 0) <% { %>
                                    <a href="/manage-schedule/inside/<%=room.room_id %>?year=<%= selectedYear %>&semester=<%= selectedSemester %>" class = "btn-edit">✎ แก้ไขตาราง</a>
                                <% } %> 
                                <% else { %>
                                    <a href="/manage-schedule/inside/new?grade=<%= room.grade_level $>&room=<%= encodeURIComponent(room.room_name)%>&year=<%= selectedYear %>&semester= <%= selectedSemester %>" class="btn-edit">✎ สร้างและจัดตาราง</a>
                                <% } %>
                            </div>
            <%
                });
                <!-- ปิด tag สุดท้ายเมื่อลูปเสร็จ -->
                if (rooms.lenght >0){
            %>
                </div></div> <% } %>
        </div>
    </div>
</body>
</html>