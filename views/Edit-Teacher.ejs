<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Student</title>
    <link rel="stylesheet" href="/css/add_stu.css">
    <link rel="stylesheet" href="/css/global.css">
</head>

<body>
    <%- include('Menu-AS') %>

    <div id="add_container">
        <form action="/update/teacher/<%= data.teacher_id %>" method="POST" enctype="multipart/form-data" id="add_form">
            <div id="form_layout">
                <div id="left_col">

                    <div id="page_header">
                        <a href="/admin/record-teach">
                            <img src="/images/icons/Back.svg" alt="ย้อนกลับ">
                        </a>
                        <h2>แก้ไขข้อมูลคุณครู</h2>
                    </div>

                    <div id="profile_upload">
                        <label for="file_input" style="cursor: pointer;">
                            <img src="<%= profileImg || '/images/icons/imgProfile.svg' %>" alt="รูปโปรไฟล์" id="profile_img" width="150" height="150" style="object-fit: cover; border-radius: 50%;">
                            <br>
                            <div id="upload">
                                <img src="/images/icons/Upload.svg" alt="ก้อนเมฆ">
                                <span>คลิกเพื่อเปลี่ยนรูปภาพใหม่</span>
                            </div>
                        </label>
                        <input type="file" name="profile_image" id="file_input" accept="image/*" style="display: none;">
                    </div>
                    
                    <p id="section_title">ข้อมูลคุณครู</p>

                    <label>ชื่อจริง</label>
                    <input type="text" name="firstname" value="<%= data.first_name %>" required>

                    <label>นามสกุล</label>
                    <input type="text" name="lastname" value="<%= data.last_name %>" required>

                <div id="right_col">

                    <label>เบอร์โทรศัพท์</label>
                    <input type="text" name="phone" value="<%= data.phone %>">

                    <label>รหัสประจำตัวนักเรียน</label>
                    <input type="text" name="student_id" value="<%= data.teacher_id %>">
                    <label>อีเมล</label>
                    <input type="email" name="email" value="<%= data.email %>">

                    <label>ห้องเรียน</label>
                    <select name="room_id">
                            <option value="">-- ไม่ระบุห้องเรียน / ไม่มีห้องประจำชั้น --</option>
                             <% rooms.forEach((room)=> { %>
                                <option value="<%= room.room_id %>" <%=data.room_id==room.room_id ? 'selected' : '' %>>
                                    <%= room.room_name %>
                                </option>
                                <% }); %>
                        </select>
                        </select>
                </div>
            </div>

            <div id="submit_area">
                <button type="submit" id="save_btn">แก้ไข</button>
            </div>
        </form>
    </div>

    <script>
        const fileInput = document.getElementById('file_input');
        const profileImg = document.getElementById('profile_img');

        fileInput.addEventListener('change', function (event) {
            const file = event.target.files[0];
            if (file) {
                const imageUrl = URL.createObjectURL(file);
                profileImg.src = imageUrl;
            }
        });
    </script>
</body>

</html>