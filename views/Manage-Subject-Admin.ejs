<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>จัดการรายวิชา</title>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@400;500;700&family=Noto+Sans+Thai:wght@100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/Manage-Subject-Admin.css">
    <link rel="icon" type="image/svg+xml" href="/images/icons/school.svg">
</head>
<body>
    <%- include('Menu-AS') %>
    
    <main class="main_content">
        <div class="top_action_bar">
            <form class="search_box" action="/admin/subject" method="GET">
                <span class="search_icon">🔍</span>
                <input type="text" name="search" placeholder="ค้นหารายวิชา..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
            </form>

            <% if (errorMsg) { %>
        <div class="alert alert-danger">
            <strong>⚠️ แจ้งเตือน:</strong> <%= errorMsg %>
        </div>  <% } %>

        <% if (successMsg) { %>
            <div class="alert alert-success">
            <strong>✅ สำเร็จ:</strong> <%= successMsg %>
            </div><% } %>

            <a href="/admin/subject/add" class="add_btn">+ เพิ่มรายวิชาใหม่</a>
        </div>

        <div class="table_container">
            <table>
                <thead>
                    <tr>
                        <th>รหัสวิชา</th>
                        <th>ชื่อวิชา</th>
                        <th>หน่วยกิต</th>
                        <th>รหัสผู้สอน</th> <th>จัดการ</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% if (subjects.length > 0) { %>
                        <% subjects.forEach(subject => { %>
                        <tr>
                            <td><%= subject.subject_id %></td>
                            <td><%= subject.subject_name %></td>
                            <td><%= subject.credit %></td>
                            <td><%= subject.teacher_id || '-' %></td> 
                            <td>
                                <a href="/admin/subject/edit/<%= subject.subject_id %>" class="edit_link">แก้ไข</a>
                            </td>
                            <td class="delete_cell">
                                <a href="/admin/subject/delete/<%= subject.subject_id %>" class="delete_icon" onclick="return confirm('คุณต้องการลบรายวิชานี้ใช่หรือไม่?');">
                                    <img src="/images/icons/Delete.svg" alt="ลบ" style="width:20px;height:20px;">
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="6" style="text-align: center; padding: 20px;">ไม่พบข้อมูลรายวิชา</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div class="bottom_action_bar">
            <button class="back_btn" onclick="window.history.back()">ย้อนกลับ</button>
            
            <div class="pagination">
                <a href="?search=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=<%= currentPage > 1 ? currentPage - 1 : 1 %>" class="page_btn">&lt;</a>
                
                <% for(let i = 1; i <= totalPages; i++) { %>
                    <a href="?search=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=<%= i %>" class="page_btn <%= currentPage === i ? 'active' : '' %>"><%= i %></a>
                <% } %>

                <a href="?search=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=<%= currentPage < totalPages ? currentPage + 1 : totalPages %>" class="page_btn">&gt;</a>
            </div>
        </div>
    </main>
</body>
</html>