<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>แก้ไขรายวิชา</title>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@400;500;700&family=Noto+Sans+Thai:wght@100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/global.css">
    
    <link rel="stylesheet" href="/css/Add-Subject-Admin.css">
</head>
<body>
    
    <%- include('Menu-AS') %>

    <main class="main_content">
    <div class="page_header">
        <a href="/admin/subject" class="back_btn">&larr;</a>
        <h2 class="page_title">แก้ไขรายชื่อวิชา</h2>
    </div>

    <div class="form_card">
        <h3 class="form_title">ข้อมูลรายวิชา</h3>
        
        <form action="/admin/subject/edit/<%= subject.subject_id %>" method="POST">
            
            <div class="input_group">
                <label>ชื่อวิชา</label>
                <input type="text" name="subject_name" value="<%= subject.subject_name %>" required>
            </div>

            <div class="input_group">
                <label>รหัสวิชา</label>
                <input type="text" name="subject_id" value="<%= subject.subject_id %>" required>
            </div>
            
            <div class="input_group">
                <label>หน่วยกิต</label>
                <input type="number" name="credit" value="<%= subject.credit %>" required>
            </div>
            
            <div class="input_group">
                <label>ระดับชั้น</label>
                <input type="number" name="grade_level" value="<%= subject.grade_level %>" required>
            </div>

            <div class="input_group">
                <label>รหัสอาจารย์ผู้สอน (Teacher ID)</label>
                <input type="number" name="teacher_id" value="<%= subject.teacher_id %>" placeholder="กรอกรหัสอาจารย์ (เช่น 1 หรือ 2)" required>
            </div>
            
            <div class="btn_container">
                <button type="submit" class="save_btn">บันทึกการแก้ไข</button>
            </div>
        </form>
    </div>
</main>

</body>
</html>