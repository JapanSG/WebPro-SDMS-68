<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/manage_stu.css">
    <link rel="stylesheet" href="/css/global.css">
</head>

<body>
    <%- include('Menu-AS') %>
        <div id="search_add">
            <div id="search">
                <img src="/images/icons/Search.svg" alt="glass">
                <input type="text" name="search" id="search_bar" placeholder="ค้นหารายชื่อนักเรียน">
            </div>
            <div id="add_btn">
                <img src="/images/icons/Add_circle.svg" alt="รูปบวก">
                <input type="button" value="เพิ่มข้อมูลนักเรียน">
            </div>
        </div>
        <table id="student_records">
            <tr id="first_head">
                <th>Student ID</th>
                <th>Full Name</th>
                <th>Gender</th>
                <th>Nationality</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Enroll Date</th>
            </tr>
            <% students.forEach((student)=>{ %>
                <tr>
                    <td>
                        <%=student.student_id%>
                    </td>
                    <td>
                        <%=student.first_name%>
                            <%=student.last_name%>
                    </td>
                    <td>
                        <%=student.sex%>
                    </td>
                    <td>
                        <%=student.nationality%>
                    </td>
                    <td>
                        <%=student.phone%>
                    </td>
                    <td>
                        <%=student.email%>
                    </td>
                    <td>
                        <%=student.enroll_date%>
                    </td>
                    <td id="S<%=student.rowid%>">
                        <a href="/edit/<%=student.student_id%>">
                            <img src="/images/icons/Delete.svg" alt="ปุ่มลบ">
                        </a>
                        <a href="/delete/<%=student.student_id%>">
                            <img src="/images/icons/Edit.svg" alt="ปุ่มแก้ไข">
                        </a>
                    </td>
                </tr>

                <% }); %>
        </table>
        <%- include('slide_next') %>
        <script>
            // ดึงค่าหน้าที่กำลังเปิดอยู่ และหน้าทั้งหมดจาก EJS มาให้ JavaScript รู้จัก
            const currentPage = parseInt("<%= currentPage %>") || 1;
            const totalPages = parseInt("<%= totalPages %>") || 1;

            // 1. กดเลขหน้า
            const pageButtons = document.querySelectorAll('.page');
            pageButtons.forEach(button => {
                button.addEventListener('click', function () {
                    window.location.href = `/?page=${this.id}`;
                });
            });

            // 2. กดปุ่มลูกศรซ้าย (ย้อนกลับ)
            document.getElementById('prev-btn').addEventListener('click', function () {
                if (currentPage > 1) { // ถ้าไม่ใช่หน้า 1 ให้ถอยไปได้
                    window.location.href = `/?page=${currentPage - 1}`;
                }
            });

            // 3. กดปุ่มลูกศรขวา (ถัดไป)
            document.getElementById('next-btn').addEventListener('click', function () {
                if (currentPage < totalPages) { // ถ้ายังไม่ถึงหน้าสุดท้าย ให้เดินหน้าได้
                    window.location.href = `/?page=${currentPage + 1}`;
                }
            });
            
        </script>
</body>

</html>