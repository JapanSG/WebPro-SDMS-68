<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance History</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/Attendance.css">
    <link rel="icon" type="image/svg+xml" href="/images/icons/school.svg">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <%- include('Menu-Student') %>
    <%- include('showMenu') %>
    
    <main class="container">
        <div class="profile-header card">
            <div class="profile-info">
                <img src="<%= user.profile_picture ? 'data:image/jpeg;base64,' + user.profile_picture.toString('base64') : '/images/icons/User.svg' %>" alt="Profile" class="avatar">
                <div class="profile-text">
                    <h2><%= student.first_name %> <%= student.last_name %></h2>
                    <p class="text-muted">ชั้น ป.<%= student.grade_level %> ห้อง <%= student.room_name %> | เลขประจำตัวนักเรียน: <%= student.student_id %></p>
                </div>
            </div>
        </div>

        <div class="summary-grid">
            <div class="summary-card card">
                <div class="card-icon">✅</div>
                <div class="card-details">
                    <h3>มาเรียน</h3>
                    <p class="count text-present"><%= summary.present %></p>
                </div>
            </div>
            <div class="summary-card card">
                <div class="card-icon">⏱️</div>
                <div class="card-details">
                    <h3>สาย</h3>
                    <p class="count text-late"><%= summary.late %></p>
                </div>
            </div>
            <div class="summary-card card">
                <div class="card-icon">❌</div>
                <div class="card-details">
                    <h3>ขาด</h3>
                    <p class="count text-absent"><%= summary.absent %></p>
                </div>
            </div>
            <div class="summary-card card">
                <div class="card-icon">😷</div>
                <div class="card-details">
                    <h3>ลากิจ</h3>
                    <p class="count text-leave"><%= summary.personal_leave %></p>
                </div>
            </div>
        </div>

        <div class="chart-section card">
            <div class="chart-header">
                <div class="legend">
                    <span class="legend-item"><span class="dot dot-green"></span> มาเรียน (Present)</span>
                    <span class="legend-item"><span class="dot dot-yellow"></span> สาย (Late)</span>
                    <span class="legend-item"><span class="dot dot-red"></span> ขาด (Absent)</span>
                    <span class="legend-item"><span class="dot dot-blue"></span> ลากิจ (Leave)</span>
                </div>
                
                <div class="filter-group">
                    <label for="filter-year">ปีการศึกษา:</label>
                    <select id="filter-year" class="semester-select" onchange="applyFilters()">
                        <% availableYears.forEach(function(year) { %>
                            <option value="<%= year %>" <%= selectedYear == year ? 'selected' : '' %>>
                                <%= year + 543 %>
                            </option>
                        <% }); %>
                    </select>

                    <label for="filter-month">เดือน:</label>
                    <select id="filter-month" class="semester-select" onchange="applyFilters()">
                        <option value="01" <%= selectedMonth === '01' ? 'selected' : '' %>>มกราคม</option>
                        <option value="02" <%= selectedMonth === '02' ? 'selected' : '' %>>กุมภาพันธ์</option>
                        <option value="03" <%= selectedMonth === '03' ? 'selected' : '' %>>มีนาคม</option>
                        <option value="04" <%= selectedMonth === '04' ? 'selected' : '' %>>เมษายน</option>
                        <option value="05" <%= selectedMonth === '05' ? 'selected' : '' %>>พฤษภาคม</option>
                        <option value="06" <%= selectedMonth === '06' ? 'selected' : '' %>>มิถุนายน</option>
                        <option value="07" <%= selectedMonth === '07' ? 'selected' : '' %>>กรกฎาคม</option>
                        <option value="08" <%= selectedMonth === '08' ? 'selected' : '' %>>สิงหาคม</option>
                        <option value="09" <%= selectedMonth === '09' ? 'selected' : '' %>>กันยายน</option>
                        <option value="10" <%= selectedMonth === '10' ? 'selected' : '' %>>ตุลาคม</option>
                        <option value="11" <%= selectedMonth === '11' ? 'selected' : '' %>>พฤศจิกายน</option>
                        <option value="12" <%= selectedMonth === '12' ? 'selected' : '' %>>ธันวาคม</option>
                    </select>
                </div>
            </div>
            
            <div class="canvas-container">
                <canvas id="attendanceChart"></canvas>
            </div>
        </div>

        <div class="history-section card">
            <h3>ประวัติการเข้าเรียน (ประจำเดือน)</h3>
            
            <div class="table-responsive">
                <table class="history-table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">วันที่</th>
                            <th style="text-align: left;">วันในสัปดาห์</th>
                            <th style="text-align: center;">สถานะ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (attendance && attendance.length > 0) { %>
                            <% attendance.forEach(function(record) { 
                                const dateObj = new Date(record.date);
                                const dateString = dateObj.toLocaleDateString('th-TH', { day: '2-digit', month: 'short', year: 'numeric' });
                                const dayName = dateObj.toLocaleDateString('th-TH', { weekday: 'long' });
                            %>
                                <tr>
                                    <td><%= dateString %></td>
                                    <td><%= dayName %></td>
                                    <td class="text-center">
                                        <% if(record.status === 'Present') { %> 
                                            <div class="status-wrap bg-present"><span class="dot dot-green"></span> มาเรียน</div>
                                        <% } else if(record.status === 'Late') { %> 
                                            <div class="status-wrap bg-late"><span class="dot dot-yellow"></span> สาย</div>
                                        <% } else if(record.status === 'Absent') { %> 
                                            <div class="status-wrap bg-absent"><span class="dot dot-red"></span> ขาด</div>
                                        <% } else if (record.status === 'Personal Leave') { %>
                                            <div class="status-wrap bg-leave"><span class="dot dot-blue"></span> ลากิจ</div>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="3" class="text-center empty-state" style="padding: 40px;">
                                    <div style="font-size: 3rem; margin-bottom: 10px;">📅</div>
                                    ไม่มีประวัติการเช็คชื่อในเดือนนี้
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        function applyFilters() {
            const month = document.getElementById('filter-month').value;
            const year = document.getElementById('filter-year').value;
            window.location.href = `/student/attendance?month=${month}&year=${year}`;
        }

        const dbChartData = <%- chartData %>;
        const ctx = document.getElementById('attendanceChart').getContext('2d');
        
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: dbChartData.labels, 
                datasets: [
                    { label: 'Present', data: dbChartData.present, backgroundColor: '#10b981', borderRadius: 4 },
                    { label: 'Late', data: dbChartData.late, backgroundColor: '#f59e0b', borderRadius: 4 },
                    { label: 'Absent', data: dbChartData.absent, backgroundColor: '#ef4444', borderRadius: 4 },
                    { label: 'Personal Leave', data: dbChartData.personal_leave, backgroundColor: '#17a2b8', borderRadius: 4 }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: { stacked: true, grid: { display: false } },
                    y: { 
                        stacked: true, 
                        beginAtZero: true, 
                        max: 1, // เพราะ 1 วันมาได้แค่ 1 ครั้ง
                        ticks: { stepSize: 1, precision: 0 } 
                    }
                },
                plugins: { legend: { display: false } }
            }
        });
    </script>
</body>
</html>