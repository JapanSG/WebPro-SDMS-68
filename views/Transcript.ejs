<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transcript</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/Transcript.css">
</head>
<body>
    <%- include('Menu-Student') %>
    <%- include('showMenu') %>
    
    <main class="container">
        <div class="profile-header card">
            <div class="profile-info">
                <img src="<%= user.profile_picture ? 'data:image/jpeg;base64,' + user.profile_picture.toString('base64') : '/images/icons/User.svg' %>" alt="Profile" class="avatar"> 
                <div class="profile-text">
                    <h2><%= student.first_name %> <%= student.last_name %></h2>
                    <p class="text-muted">ชั้น ม.<%= student.grade_level || student.year %> ห้อง <%= student.room_name || student.room_id %> | เลขประจำตัวนักเรียน: <%= student.student_id %></p>
                </div>
            </div>
        </div>

        <div class="summary-grid" style="grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 20px;">
            
            <div class="card" style="display: flex; flex-direction: column; justify-content: center;">
                <h3 style="margin-top: 0;">ค้นหาผลการเรียน</h3>
                <div class="filter-group" style="margin-top: 1rem; display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                    
                    <div>
                        <label for="filter-year" style="font-weight: bold; margin-right: 5px;">ปีการศึกษา:</label>
                        <select id="filter-year" class="semester-select" onchange="applyFilters()" style="padding: 8px; border-radius: 5px; border: 1px solid #ccc;">
                            <% availableYears.forEach(function(year) { %>
                                <option value="<%= year %>" <%= selectedYear == year ? 'selected' : '' %>>
                                    <%= year + 543 %>
                                </option>
                            <% }); %>
                        </select>
                    </div>

                    <div>
                        <label for="filter-term" style="font-weight: bold; margin-right: 5px;">ภาคเรียน:</label>
                        <select id="filter-term" class="semester-select" onchange="applyFilters()" style="padding: 8px; border-radius: 5px; border: 1px solid #ccc;">
                            <option value="1" <%= selectedTerm === '1' ? 'selected' : '' %>>ภาคเรียนที่ 1</option>
                            <option value="2" <%= selectedTerm === '2' ? 'selected' : '' %>>ภาคเรียนที่ 2</option>
                        </select>
                    </div>

                </div>
            </div>

            <div class="gpa-card card" style="text-align: center; display: flex; flex-direction: column; justify-content: center;">
                <h3 style="margin-top: 0; color: #64748b;">เกรดเฉลี่ยประจำภาคเรียน</h3>
                <p class="gpa-score" style="font-size: 3rem; font-weight: bold; color: #3b82f6; margin: 10px 0;"><%= termGPA %></p>
                <p style="margin: 0; opacity: 0.8; font-weight: bold;">หน่วยกิตรวม: <%= totalCredits %></p>
            </div>
        </div>

        <div class="history-section card">
            <h3 style="margin-top: 0; border-bottom: 2px solid #e2e8f0; padding-bottom: 10px;">ผลการเรียน (Transcript)</h3>
            
            <div style="overflow-x: auto;">
                <table class="history-table" style="width: 100%; border-collapse: collapse; margin-top: 15px; min-width: 600px;">
                    <thead>
                        <tr style="background-color: #f8fafc; border-bottom: 2px solid #3b82f6;">
                            <th style="padding: 15px; text-align: left; color: #1e293b;">รหัสวิชา</th>
                            <th style="padding: 15px; text-align: left; color: #1e293b;">ชื่อวิชา</th>
                            <th style="padding: 15px; text-align: center; color: #1e293b;">หน่วยกิต</th>
                            <th style="padding: 15px; text-align: center; color: #1e293b;">เกรดที่ได้</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if ( grades && grades.length > 0) { %>
                            <% grades.forEach(function(record) { 
                                // ลอจิกเปลี่ยนสีเกรด: 4=เขียว, 0=แดง, อื่นๆ=สีพื้นฐาน
                                let gradeClass = '';
                                let gradeNum = parseFloat(record.grade);
                                
                                if (gradeNum >= 3.5) { gradeClass = 'color: #10b981; background: #d1fae5;'; } 
                                else if (gradeNum > 0) { gradeClass = 'color: #3b82f6; background: #dbeafe;'; }
                                else if (gradeNum === 0) { gradeClass = 'color: #ef4444; background: #fee2e2;'; }
                            %>
                                <tr style="border-bottom: 1px solid #e2e8f0; transition: 0.3s;">
                                    <td style="padding: 15px;"><%= record.subject_id %></td>
                                    <td style="padding: 15px; font-weight: bold;"><%= record.subject_name || 'ไม่ระบุชื่อวิชา' %></td>
                                    <td style="padding: 15px; text-align: center;"><%= record.credit || '-' %></td>
                                    <td style="padding: 15px; text-align: center;">
                                        <span style="padding: 5px 15px; border-radius: 20px; font-weight: bold; <%= gradeClass %>">
                                            <%= record.grade %>
                                        </span>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center" style="padding: 5rem 0; color: #94a3b8; font-size: 1.1rem; text-align: center;">
                                    <div style="font-size: 4rem; margin-bottom: 15px;">📄</div>
                                    ยังไม่มีการบันทึกผลการเรียนในปีการศึกษาและภาคเรียนนี้
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        // ฟังก์ชันเมื่อผู้ใช้กดเปลี่ยนปี หรือเปลี่ยนเทอม ใน Dropdown
        function applyFilters() {
            const term = document.getElementById('filter-term').value;
            const year = document.getElementById('filter-year').value;
            
            // สั่งให้เบราว์เซอร์รีเฟรชหน้าเว็บ ไปดึงข้อมูลชุดใหม่มาแสดง
            window.location.href = `/student/transcript-grade?term=${term}&year=${year}`;
        }
    </script>
</body>
</html>