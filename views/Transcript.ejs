<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transcript</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/Transcript.css">
    <link rel="icon" type="image/svg+xml" href="/images/icons/school.svg">
</head>
<body>
    <%- include('Menu-Student') %>
    <%- include('showMenu') %>
    
    <main class="container">
        <div class="profile-header card">
            <div class="profile-info">
                <img src="<%= user.profile_picture ? 'data:image/jpeg;base64,' + user.profile_picture.toString('base64') : '/images/icons/User.svg' %>" alt="Profile" class="avatar"> 
                <div class="profile-text">
                    <h2><%= student.first_name %> <%= student.last_name %></h2>
                    <p class="text-muted">ชั้น ป.<%= student.grade_level || student.year %> ห้อง <%= student.room_name || student.room_id %> | เลขประจำตัว: <%= student.student_id %></p>
                </div>
            </div>
        </div>

        <div class="summary-grid">
            
            <div class="card filter-card">
                <h3>ค้นหาผลการเรียน</h3>
                <div class="filter-group">
                    <div class="filter-item">
                        <label for="filter-year">ปีการศึกษา:</label>
                        <select id="filter-year" class="semester-select" onchange="applyFilters()">
                            <% availableYears.forEach(function(year) { %>
                                <option value="<%= year %>" <%= selectedYear == year ? 'selected' : '' %>>
                                    <%= year + 543 %>
                                </option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="filter-item">
                        <label for="filter-term">ภาคเรียน:</label>
                        <select id="filter-term" class="semester-select" onchange="applyFilters()">
                            <option value="1" <%= selectedTerm === '1' ? 'selected' : '' %>>ภาคเรียนที่ 1</option>
                            <option value="2" <%= selectedTerm === '2' ? 'selected' : '' %>>ภาคเรียนที่ 2</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="gpa-card card">
                <h3>เกรดเฉลี่ยประจำภาคเรียน</h3>
                <p class="gpa-score"><%= termGPA %></p>
                <p class="gpa-credit">หน่วยกิตรวม: <%= totalCredits %></p>
            </div>
            
        </div>

        <div class="history-section card">
            <h3>ผลการเรียน (Transcript)</h3>
            
            <div class="table-responsive">
                <table class="history-table">
                    <thead>
                        <tr>
                            <th>รหัสวิชา</th>
                            <th>ชื่อวิชา</th>
                            <th class="text-center">หน่วยกิต</th>
                            <th class="text-center">เกรดที่ได้</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (grades && grades.length > 0) { %>
                            <% grades.forEach(function(record) { 
                                let gradeClass = 'grade-default';
                                let numGrade = parseFloat(record.grade);
                                if (numGrade >= 3.5) gradeClass = 'grade-4';
                                else if (numGrade >= 2.5) gradeClass = 'grade-3';
                                else if (numGrade >= 1.5) gradeClass = 'grade-2';
                                else if (numGrade === 0) gradeClass = 'grade-0';
                            %>
                                <tr>
                                    <td><%= record.subject_id %></td>
                                    <td class="fw-bold"><%= record.subject_name || 'ไม่ระบุชื่อวิชา' %></td>
                                    <td class="text-center"><%= record.credit || '-' %></td>
                                    <td class="text-center">
                                        <span class="grade-badge <%= gradeClass %>"><%= record.grade %></span>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center empty-state">
                                    <div class="empty-icon">📄</div>
                                    ยังไม่มีการบันทึกผลการเรียนในภาคเรียนนี้
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        // ฟังก์ชันเมื่อผู้ใช้กดเปลี่ยนปี หรือเปลี่ยนเทอม ใน Dropdown
        function applyFilters() {
            const term = document.getElementById('filter-term').value;
            const year = document.getElementById('filter-year').value;
            // ดึงค่าตามตัวกรองเป๊ะๆ ไม่มีการล็อคตามเดือนอีกต่อไป
            window.location.href = `/student/transcript-grade?term=${term}&year=${year}`;
        }
    </script>
</body>
</html>